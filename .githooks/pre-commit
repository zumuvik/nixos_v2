#!/usr/bin/env bash
set -euo pipefail

files=()
while IFS= read -r -d "" file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -z -- '*.nix')

if (( ${#files[@]} == 0 )); then
  exit 0
fi

echo "Formatting staged Nix files..."
nix run .#format -- "${files[@]}"
git add -- "${files[@]}"
git diff --cached --check
